.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

################################################################################
# BACKEND - Runtime Data & Temporary Files
################################################################################
backend/__pycache__/
backend/*.log
backend/*.pyc
backend/uploads/*
backend/results/*
!backend/uploads/.gitkeep
!backend/results/.gitkeep

# Model checkpoints (exclude all .pt files except best.pt)
backend/models/*.pt
!backend/models/best.pt

################################################################################
